<form class="cpr-rolltable-dashboard-form">
  <header class="cpr-dashboard-hero">
    <div>
      <p class="cpr-kicker">{{localize "cpr-rolltable-dashboard.ui.kicker"}}</p>
      <h1>{{localize "cpr-rolltable-dashboard.title"}}</h1>
      <p>{{localize "cpr-rolltable-dashboard.ui.subtitle"}}</p>
    </div>
    {{#if isGM}}
      <button type="button" class="cpr-primary-action js-import-bundled">{{localize "cpr-rolltable-dashboard.button.import"}}</button>
    {{/if}}
  </header>

  <nav class="cpr-dashboard-tabs tabs" data-group="primary">
    <a class="item active" data-tab="generators"><i class="fas fa-bolt"></i> {{localize "cpr-rolltable-dashboard.section.generators"}}</a>
    <a class="item" data-tab="tables"><i class="fas fa-table-list"></i> {{localize "cpr-rolltable-dashboard.section.bundled"}}</a>
    <a class="item" data-tab="chains"><i class="fas fa-link"></i> {{localize "cpr-rolltable-dashboard.section.customChains"}}</a>
  </nav>

  <div class="cpr-dashboard-shell">
    <section class="cpr-dashboard-body">
      <div class="tab active" data-tab="generators">
        <section class="cpr-panel">
          <div class="cpr-panel-heading">
            <h2>{{localize "cpr-rolltable-dashboard.ui.sceneBuilder"}}</h2>
            <p>{{localize "cpr-rolltable-dashboard.ui.sceneBuilderHelp"}}</p>
          </div>
          <div class="cpr-scene-categories">
            <section class="cpr-scene-category">
              <div class="cpr-scene-category-heading">
                <span>{{localize "cpr-rolltable-dashboard.ui.economy"}}</span>
                <p>{{localize "cpr-rolltable-dashboard.ui.economyHelp"}}</p>
              </div>
              <div class="cpr-action-grid">
                <article class="cpr-action-card cpr-accent-market">
                  <span>{{localize "cpr-rolltable-dashboard.ui.economy"}}</span>
                  <h3>{{localize "cpr-rolltable-dashboard.generator.nightMarket"}}</h3>
                  <p>{{localize "cpr-rolltable-dashboard.ui.nightMarketHelp"}}</p>
                  <button type="button" class="js-generate-night-market">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>
                </article>
                <article class="cpr-action-card cpr-accent-merchant">
                  <span>{{localize "cpr-rolltable-dashboard.ui.inventory"}}</span>
                  <h3>{{localize "cpr-rolltable-dashboard.generator.merchant"}}</h3>
                  <p>{{localize "cpr-rolltable-dashboard.ui.merchantHelp"}}</p>
                  <div class="cpr-inline-controls">
                    <select name="merchantCategory">{{selectOptions categoryChoices selected="random" localize=true}}</select>
                    <button type="button" class="js-generate-merchant">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>
                  </div>
                </article>
              </div>
            </section>
            <section class="cpr-scene-category">
              <div class="cpr-scene-category-heading">
                <span>{{localize "cpr-rolltable-dashboard.ui.hustles"}}</span>
                <p>{{localize "cpr-rolltable-dashboard.ui.hustlesHelp"}}</p>
              </div>
              <div class="cpr-action-grid">
                <article class="cpr-action-card cpr-accent-net">
                  <span>{{localize "cpr-rolltable-dashboard.ui.net"}}</span>
                  <h3>{{localize "cpr-rolltable-dashboard.generator.netrunnerHustle"}}</h3>
                  <p>{{localize "cpr-rolltable-dashboard.ui.hustleHelp"}}</p>
                  <div class="cpr-inline-controls">
                    <select name="netrunnerRankBand">{{selectOptions rankChoices selected="rank1to4" localize=true}}</select>
                    <button type="button" class="js-generate-netrunner-hustle">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>
                  </div>
                </article>
              </div>
            </section>
            {{#each sceneBuilderGroups as |group|}}
              <section class="cpr-scene-category">
                <div class="cpr-scene-category-heading">
                  <span>{{group.label}}</span>
                  <p>{{group.description}}</p>
                </div>
                {{#if group.tables.length}}
                  <div class="cpr-scene-table-grid">
                    {{#each group.tables as |table|}}
                      <button type="button" class="cpr-scene-table-button js-roll-bundled-table" data-table-key="{{table.key}}">
                        <strong>{{table.name}}</strong>
                        <span>{{table.formula}}</span>
                      </button>
                    {{/each}}
                  </div>
                {{else}}
                  <p class="cpr-empty-note">{{localize "cpr-rolltable-dashboard.table.emptySource"}}</p>
                {{/if}}
              </section>
            {{/each}}
            <section class="cpr-scene-category">
              <div class="cpr-scene-category-heading">
                <span>{{localize "cpr-rolltable-dashboard.ui.street"}}</span>
                <p>{{localize "cpr-rolltable-dashboard.ui.streetHelp"}}</p>
              </div>
              <div class="cpr-action-grid">
                <article class="cpr-action-card cpr-accent-street">
                  <span>{{localize "cpr-rolltable-dashboard.ui.pressure"}}</span>
                  <h3>{{localize "cpr-rolltable-dashboard.generator.encounter"}}</h3>
                  <p>{{localize "cpr-rolltable-dashboard.ui.encounterHelp"}}</p>
                  <div class="cpr-inline-controls">
                    <select name="encounterPeriod">{{selectOptions periodChoices selected="day" localize=true}}</select>
                    <button type="button" class="js-generate-encounter">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>
                  </div>
                </article>
              </div>
            </section>
          </div>
        </section>
      </div>

      <div class="tab" data-tab="tables">
        <section class="cpr-panel">
          <div class="cpr-panel-heading">
            <h2>{{localize "cpr-rolltable-dashboard.section.bundled"}}</h2>
            <p>{{localize "cpr-rolltable-dashboard.import.help"}}</p>
          </div>
          <div class="cpr-table-groups">
            {{#each datatermGroups as |group|}}
              <article class="cpr-table-group">
                <div class="cpr-table-group-header">
                  <h3>{{group.label}}</h3>
                  <p>{{group.description}}</p>
                </div>
                {{#if group.tables.length}}
                  <ol class="cpr-table-list">
                    {{#each group.tables as |table|}}
                      <li>
                        <div>
                          <strong>{{table.name}}</strong>
                          <span>{{table.formula}}</span>
                        </div>
                        <button type="button" class="js-roll-bundled-table" data-table-key="{{table.key}}">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>
                      </li>
                    {{/each}}
                  </ol>
                {{else}}
                  <p class="cpr-empty-note">{{localize "cpr-rolltable-dashboard.table.emptySource"}}</p>
                {{/if}}
              </article>
            {{/each}}
          </div>
        </section>
      </div>

      <div class="tab" data-tab="chains">
        <section class="cpr-panel">
          <div class="cpr-panel-heading cpr-heading-actions">
            <div>
              <h2>{{localize "cpr-rolltable-dashboard.section.customChains"}}</h2>
              <p>{{localize "cpr-rolltable-dashboard.ui.chainsHelp"}}</p>
            </div>
            {{#if isGM}}<button type="button" class="js-add-chain">{{localize "cpr-rolltable-dashboard.button.addChain"}}</button>{{/if}}
          </div>
          {{#if customChains.length}}
            <div class="cpr-chain-list">
              {{#each customChains as |chain|}}
                <article class="cpr-chain-card" data-chain-id="{{chain.id}}">
                  <div class="cpr-chain-meta">
                    <label>{{localize "cpr-rolltable-dashboard.customChain.name"}}<input type="text" name="chain-name" value="{{chain.name}}" /></label>
                    <label>{{localize "cpr-rolltable-dashboard.customChain.category"}}<input type="text" name="chain-category" value="{{chain.category}}" /></label>
                  </div>
                  <ol class="cpr-chain-steps">
                    {{#each chain.steps as |step|}}
                      <li class="cpr-chain-step" data-step-index="{{@index}}">
                        <label>{{localize "cpr-rolltable-dashboard.customChain.step"}}<input type="text" name="step-label" value="{{step.label}}" /></label>
                        <label>{{localize "cpr-rolltable-dashboard.customChain.table"}}<select name="step-table-uuid">{{selectOptions ../../tableChoices selected=step.tableUuid}}</select></label>
                        <label>{{localize "cpr-rolltable-dashboard.customChain.repeatMode"}}<select name="step-repeat-mode">{{selectOptions ../../repeatChoices selected=step.repeatMode localize=true}}</select></label>
                        <label>{{localize "cpr-rolltable-dashboard.ui.repeatCount"}}<input type="number" min="1" name="step-repeat-value" value="{{step.repeatValue}}" /></label>
                        {{#if ../../isGM}}<button type="button" class="js-remove-step" data-chain-id="{{../id}}" data-step-index="{{@index}}">{{localize "cpr-rolltable-dashboard.button.removeStep"}}</button>{{/if}}
                      </li>
                    {{/each}}
                  </ol>
                  <div class="cpr-chain-actions">
                    {{#if ../isGM}}
                      <button type="button" class="js-add-step" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.addStep"}}</button>
                      <button type="button" class="js-save-chain" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.saveChain"}}</button>
                      <button type="button" class="js-delete-chain" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.deleteChain"}}</button>
                    {{/if}}
                    <button type="button" class="cpr-primary-action js-run-chain" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.runChain"}}</button>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="cpr-empty-note">{{localize "cpr-rolltable-dashboard.customChain.none"}}</p>
          {{/if}}
        </section>
      </div>
    </section>

    <aside class="cpr-result-panel {{#unless lastResult}}is-empty{{/unless}}">
      <div class="cpr-result-header">
        <p class="cpr-kicker">{{localize "cpr-rolltable-dashboard.result.kicker"}}</p>
        <h2>{{localize "cpr-rolltable-dashboard.result.title"}}</h2>
      </div>
      <div class="cpr-result-empty" {{#if lastResult}}style="display:none"{{/if}}>
        <i class="fas fa-dice-d20"></i>
        <p>{{localize "cpr-rolltable-dashboard.result.empty"}}</p>
      </div>
      <div class="cpr-result-content" {{#unless lastResult}}style="display:none"{{/unless}}>
        <div class="cpr-result-meta">
          <strong class="cpr-result-title">{{lastResult.title}}</strong>
          <span class="cpr-result-time">{{lastResult.timestamp}}</span>
        </div>
        <ol class="cpr-result-lines">
          {{#each lastResult.lines as |line|}}
            <li>{{{line}}}</li>
          {{/each}}
        </ol>
      </div>
    </aside>
  </div>
</form>
