<form class="cpr-rolltable-dashboard-form">
  <header class="cpr-dashboard-hero">
    <div>
      <p class="cpr-kicker">{{localize "cpr-rolltable-dashboard.ui.kicker"}}</p>
      <h1>{{localize "cpr-rolltable-dashboard.title"}}</h1>
      <p>{{localize "cpr-rolltable-dashboard.ui.subtitle"}}</p>
    </div>
    <div class="cpr-hero-actions">
      <label class="cpr-chat-toggle">
        <input type="checkbox" class="js-toggle-public-chat" {{#if postToChat}}checked{{/if}} />
        <span>{{localize "cpr-rolltable-dashboard.ui.postToChat"}}</span>
      </label>
      {{#if isGM}}
        <button type="button" class="cpr-primary-action js-import-bundled">{{localize "cpr-rolltable-dashboard.button.import"}}</button>
      {{/if}}
    </div>
  </header>

  <nav class="cpr-dashboard-tabs tabs" data-group="primary">
    <a class="item active" data-tab="generators"><i class="fas fa-bolt"></i> {{localize "cpr-rolltable-dashboard.section.generators"}}</a>
    <a class="item" data-tab="tables"><i class="fas fa-table-list"></i> {{localize "cpr-rolltable-dashboard.section.bundled"}}</a>
    <a class="item" data-tab="chains"><i class="fas fa-link"></i> {{localize "cpr-rolltable-dashboard.section.customChains"}}</a>
  </nav>

  <div class="cpr-dashboard-shell">
    <section class="cpr-dashboard-body">
      <div class="tab active" data-tab="generators">
        <section class="cpr-panel">
          <div class="cpr-panel-heading cpr-heading-actions">
            <div>
              <h2>{{localize "cpr-rolltable-dashboard.ui.sceneBuilder"}}</h2>
              <p>{{localize "cpr-rolltable-dashboard.ui.sceneBuilderHelp"}}</p>
            </div>
            <div class="cpr-customize-actions">
              <button type="button" class="cpr-configure-deck js-toggle-customize {{#if sceneLayout.isCustomizing}}is-active{{/if}}"><i class="fas fa-sliders"></i> {{localize "cpr-rolltable-dashboard.button.configureDeck"}}</button>
              <button type="button" class="cpr-reset-layout js-reset-scene-layout">{{localize "cpr-rolltable-dashboard.button.resetLayout"}}</button>
            </div>
          </div>
          <div class="cpr-scene-categories {{#if sceneLayout.isCustomizing}}is-customizing{{/if}}">
            <section class="cpr-scene-category cpr-quick-access" data-category-id="quick-access">
              <div class="cpr-scene-category-heading">
                <div>
                  <span>{{localize "cpr-rolltable-dashboard.group.neuralCache"}}</span>
                  <p>{{localize "cpr-rolltable-dashboard.group.neuralCacheHelp"}}</p>
                </div>
              </div>
              {{#if hasQuickAccessCards}}
                <div class="cpr-action-grid">
                  {{#each quickAccessCards as |card|}}
                    <article class="cpr-action-card {{card.accentClass}} {{#if card.isFavorite}}is-favorite{{/if}}" data-card-id="{{card.id}}">
                      <div class="cpr-card-controls">
                        <button type="button" class="cpr-pin-toggle js-toggle-card-favorite {{#if card.isFavorite}}is-pinned{{/if}}" role="switch" aria-checked="{{#if card.isFavorite}}true{{else}}false{{/if}}" aria-label='{{localize "cpr-rolltable-dashboard.aria.pinCard"}}'><i class="fas fa-star"></i></button>
                      </div>
                      <span>{{card.eyebrow}}</span>
                      <h3>{{card.title}}</h3>
                      <p>{{card.help}}</p>
                      {{#if card.hasMerchantControl}}<div class="cpr-inline-controls"><select name="merchantCategory">{{selectOptions ../categoryChoices selected="random" localize=true}}</select><button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button></div>{{else}}
                      {{#if card.hasRoleHustleControl}}<div class="cpr-inline-controls cpr-inline-controls-stacked"><select name="roleHustleGenerator">{{selectOptions ../roleHustleChoices}}</select><select name="roleHustleRankBand">{{selectOptions ../rankChoices selected="rank1to4" localize=true}}</select><button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button></div>{{else}}
                      {{#if card.hasEncounterControl}}<div class="cpr-inline-controls"><select name="encounterPeriod">{{selectOptions ../periodChoices selected="day" localize=true}}</select><button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button></div>{{else}}
                      <button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>{{/if}}{{/if}}{{/if}}
                    </article>
                  {{/each}}
                </div>
              {{else}}
                <p class="cpr-empty-note">{{localize "cpr-rolltable-dashboard.group.neuralCacheEmpty"}}</p>
              {{/if}}
            </section>
            {{#each sceneBuilderCategories}}
              <section class="cpr-scene-category {{#if isHidden}}is-hidden{{/if}}" data-category-id="{{id}}" draggable="{{#if isCustomizing}}true{{else}}false{{/if}}">
                <div class="cpr-scene-category-heading">
                  <button type="button" class="cpr-drag-handle" aria-label='{{localize "cpr-rolltable-dashboard.aria.dragCategory"}}'><i class="fas fa-grip-vertical"></i></button>
                  <div>
                    <span>{{label}}</span>
                    <p>{{description}}</p>
                  </div>
                  <button type="button" class="cpr-visibility-toggle js-toggle-category-visibility" aria-expanded="{{#if isHidden}}false{{else}}true{{/if}}" aria-label='{{localize "cpr-rolltable-dashboard.aria.toggleCategory"}}'><i class="fas {{#if isHidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i></button>
                </div>
                <div class="cpr-action-grid">
                  {{#each cards}}
                    <article class="cpr-action-card {{accentClass}} {{#if isFavorite}}is-favorite{{/if}}" data-card-id="{{id}}" draggable="{{#if isCustomizing}}true{{else}}false{{/if}}">
                      <div class="cpr-card-controls">
                        <button type="button" class="cpr-pin-toggle js-toggle-card-favorite {{#if isFavorite}}is-pinned{{/if}}" role="switch" aria-checked="{{#if isFavorite}}true{{else}}false{{/if}}" aria-label='{{localize "cpr-rolltable-dashboard.aria.pinCard"}}'><i class="fas fa-star"></i></button>
                        <button type="button" class="cpr-drag-handle" aria-label='{{localize "cpr-rolltable-dashboard.aria.dragCard"}}'><i class="fas fa-grip-vertical"></i></button>
                      </div>
                      <span>{{eyebrow}}</span>
                      <h3>{{title}}</h3>
                      <p>{{help}}</p>
                      {{#if hasMerchantControl}}<div class="cpr-inline-controls"><select name="merchantCategory">{{selectOptions ../../categoryChoices selected="random" localize=true}}</select><button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button></div>{{else}}
                      {{#if hasRoleHustleControl}}<div class="cpr-inline-controls cpr-inline-controls-stacked"><select name="roleHustleGenerator">{{selectOptions ../../roleHustleChoices}}</select><select name="roleHustleRankBand">{{selectOptions ../../rankChoices selected="rank1to4" localize=true}}</select><button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button></div>{{else}}
                      {{#if hasEncounterControl}}<div class="cpr-inline-controls"><select name="encounterPeriod">{{selectOptions ../../periodChoices selected="day" localize=true}}</select><button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button></div>{{else}}
                      <button type="button" class="js-run-scene-card">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>{{/if}}{{/if}}{{/if}}
                    </article>
                  {{/each}}
                </div>
              </section>
            {{/each}}
          </div>
        </section>
      </div>

      <div class="tab" data-tab="tables">
        <section class="cpr-panel">
          <div class="cpr-panel-heading">
            <h2>{{localize "cpr-rolltable-dashboard.section.bundled"}}</h2>
            <p>{{localize "cpr-rolltable-dashboard.import.help"}}</p>
          </div>
          <div class="cpr-table-groups">
            {{#each datatermGroups as |group|}}
              <article class="cpr-table-group">
                <div class="cpr-table-group-header">
                  <h3>{{group.label}}</h3>
                  <p>{{group.description}}</p>
                </div>
                {{#if group.tables.length}}
                  <ol class="cpr-table-list">
                    {{#each group.tables as |table|}}
                      <li>
                        <div>
                          <strong>{{table.name}}</strong>
                          <span>{{table.formula}}</span>
                        </div>
                        <button type="button" class="js-roll-bundled-table" data-table-key="{{table.key}}">{{localize "cpr-rolltable-dashboard.button.roll"}}</button>
                      </li>
                    {{/each}}
                  </ol>
                {{else}}
                  <p class="cpr-empty-note">{{localize "cpr-rolltable-dashboard.table.emptySource"}}</p>
                {{/if}}
              </article>
            {{/each}}
          </div>
        </section>
      </div>

      <div class="tab" data-tab="chains">
        <section class="cpr-panel">
          <div class="cpr-panel-heading cpr-heading-actions">
            <div>
              <h2>{{localize "cpr-rolltable-dashboard.section.customChains"}}</h2>
              <p>{{localize "cpr-rolltable-dashboard.ui.chainsHelp"}}</p>
            </div>
            {{#if isGM}}<button type="button" class="js-add-chain">{{localize "cpr-rolltable-dashboard.button.addChain"}}</button>{{/if}}
          </div>
          {{#if customChains.length}}
            <div class="cpr-chain-list">
              {{#each customChains as |chain|}}
                <article class="cpr-chain-card" data-chain-id="{{chain.id}}">
                  <div class="cpr-chain-meta">
                    <label>{{localize "cpr-rolltable-dashboard.customChain.name"}}<input type="text" name="chain-name" value="{{chain.name}}" /></label>
                    <label>{{localize "cpr-rolltable-dashboard.customChain.category"}}<input type="text" name="chain-category" value="{{chain.category}}" /></label>
                  </div>
                  <ol class="cpr-chain-steps">
                    {{#each chain.steps as |step|}}
                      <li class="cpr-chain-step" data-step-index="{{@index}}">
                        <label>{{localize "cpr-rolltable-dashboard.customChain.step"}}<input type="text" name="step-label" value="{{step.label}}" /></label>
                        <label>{{localize "cpr-rolltable-dashboard.customChain.table"}}<select name="step-table-uuid">{{selectOptions ../../tableChoices selected=step.tableUuid}}</select></label>
                        <label>{{localize "cpr-rolltable-dashboard.customChain.repeatMode"}}<select name="step-repeat-mode">{{selectOptions ../../repeatChoices selected=step.repeatMode localize=true}}</select></label>
                        <label>{{localize "cpr-rolltable-dashboard.ui.repeatCount"}}<input type="number" min="1" name="step-repeat-value" value="{{step.repeatValue}}" /></label>
                        {{#if ../../isGM}}<button type="button" class="js-remove-step" data-chain-id="{{../id}}" data-step-index="{{@index}}">{{localize "cpr-rolltable-dashboard.button.removeStep"}}</button>{{/if}}
                      </li>
                    {{/each}}
                  </ol>
                  <div class="cpr-chain-actions">
                    {{#if ../isGM}}
                      <button type="button" class="js-add-step" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.addStep"}}</button>
                      <button type="button" class="js-save-chain" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.saveChain"}}</button>
                      <button type="button" class="js-delete-chain" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.deleteChain"}}</button>
                    {{/if}}
                    <button type="button" class="cpr-primary-action js-run-chain" data-chain-id="{{chain.id}}">{{localize "cpr-rolltable-dashboard.button.runChain"}}</button>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="cpr-empty-note">{{localize "cpr-rolltable-dashboard.customChain.none"}}</p>
          {{/if}}
        </section>
      </div>
    </section>

    <aside class="cpr-result-panel {{#unless hasResultHistory}}is-empty{{/unless}}">
      <div class="cpr-result-header">
        <div>
          <p class="cpr-kicker">{{localize "cpr-rolltable-dashboard.result.kicker"}}</p>
          <h2>{{localize "cpr-rolltable-dashboard.result.title"}}</h2>
        </div>
        <button type="button" class="cpr-clear-history js-clear-result-history" {{#unless hasResultHistory}}style="display:none"{{/unless}}>{{localize "cpr-rolltable-dashboard.button.clearHistory"}}</button>
      </div>
      <div class="cpr-result-empty" {{#if hasResultHistory}}style="display:none"{{/if}}>
        <i class="fas fa-dice-d20"></i>
        <p>{{localize "cpr-rolltable-dashboard.result.empty"}}</p>
      </div>
      <div class="cpr-result-content" {{#unless hasResultHistory}}style="display:none"{{/unless}}>
        <div class="cpr-result-feed">
          {{#each resultHistory as |result|}}
            <article class="cpr-result-entry">
              <div class="cpr-result-meta">
                <strong class="cpr-result-title">{{{result.title}}}</strong>
                <span class="cpr-result-time">{{result.timestamp}}</span>
              </div>
              {{#if ../isGM}}
                {{#if result.canPopulateMerchants}}
                  <div class="cpr-result-actions">
                    <button type="button" class="cpr-result-action js-populate-night-market-merchants" data-result-id="{{result.id}}">{{localize "cpr-rolltable-dashboard.button.populateMerchants"}}</button>
                  </div>
                {{/if}}
              {{/if}}
              <ol class="cpr-result-lines">
                {{#each result.lines as |line|}}
                  <li>{{{line}}}</li>
                {{/each}}
              </ol>
            </article>
          {{/each}}
        </div>
      </div>
    </aside>
  </div>
</form>
